# Documentation only. The preview launcher does not load .env files.
# Use `python bot.py configure` so credentials are stored outside the repository.
KALSHI_BASE_URL=https://external-api.demo.kalshi.co/trade-api/v2
DRY_RUN=1
ALLOW_SYSTEM_PROXY=0
